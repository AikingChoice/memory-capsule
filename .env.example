# ===== 模型配置 =====
# 用的是 OpenAI 兼容接口，换模型只改这里就行
# 以下以 DeepSeek + 小米 MiMo 为例

# 主模型
PRIMARY_API_KEY=sk-your-deepseek-key
PRIMARY_BASE_URL=https://api.deepseek.com
PRIMARY_MODEL=deepseek-chat

# 备用模型（可选，留空则不启用自动切换）
BACKUP_API_KEY=
BACKUP_BASE_URL=
BACKUP_MODEL=

# ===== 应用配置 =====
APP_HOST=0.0.0.0
APP_PORT=8000
WHISPER_MODEL_SIZE=base
MAX_AUDIO_SIZE_MB=50
